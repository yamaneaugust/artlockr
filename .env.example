# ArtLockr Configuration

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=ArtLockr - Copyright Detection API
VERSION=1.0.0

# CORS Settings (comma-separated)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database
DATABASE_URL=postgresql+asyncpg://artlockr:artlockr@localhost/artlockr_db

# File Storage
UPLOAD_DIR=data/uploads
AI_GENERATED_DIR=data/ai_generated
FEATURES_DIR=data/features
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ML Model Settings
MODEL_NAME=resnet50  # Options: resnet50, resnet101, resnet152
MODEL_WEIGHTS=IMAGENET1K_V2
SIMILARITY_THRESHOLD=0.85  # 0.0 to 1.0
BATCH_SIZE=32
DEVICE=cuda  # cuda or cpu
FEATURE_DIM=2048

# API Security
SECRET_KEY=your-secret-key-change-in-production-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Gating
ENABLE_API_GATING=True
RATE_LIMIT_PER_MINUTE=10
