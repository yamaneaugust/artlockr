# ArtLock Environment Configuration
# Copy this file to .env and fill in your values

# ===================================
# General Configuration
# ===================================
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
PROJECT_NAME=ArtLock - AI-Powered Copyright Detection
VERSION=1.0.0

# ===================================
# Database Configuration
# ===================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://artlockr:artlockr_password@localhost:5432/artlockr_db

# Database credentials (used by Docker Compose)
DB_PASSWORD=artlockr_password

# ===================================
# Security
# ===================================
# Secret key for JWT tokens (CHANGE THIS IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production

# JWT settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===================================
# API Configuration
# ===================================
API_V1_STR=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ===================================
# Frontend Configuration
# ===================================
VITE_API_URL=http://localhost:8000/api/v1
VITE_ENV=development

# ===================================
# ML Model Configuration
# ===================================
MODEL_NAME=resnet50  # resnet50, resnet101, resnet152
MODEL_WEIGHTS=IMAGENET1K_V2
DEVICE=cpu  # cpu or cuda
BATCH_SIZE=32
FEATURE_DIM=2048
SIMILARITY_THRESHOLD=0.85

# ===================================
# FAISS Configuration
# ===================================
FAISS_INDEX_TYPE=ivf  # flat, ivf, hnsw
FAISS_INDEX_PATH=data/faiss_indexes/artwork_index.faiss
FAISS_NLIST=100  # Number of clusters for IVF index
FAISS_NPROBE=10  # Number of clusters to visit during search

# ===================================
# Storage Configuration
# ===================================
DATA_DIR=data
UPLOAD_DIR=data/uploads
FEATURES_DIR=data/features
AI_IMAGES_DIR=data/ai_images
FAISS_INDEXES_DIR=data/faiss_indexes
BACKUPS_DIR=data/backups

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=10

# ===================================
# Privacy & Compliance
# ===================================
# Default storage mode: features_only, temporary, permanent
DEFAULT_STORAGE_MODE=features_only

# Consent version (increment when privacy policy changes)
CONSENT_VERSION=1.0

# Cookie consent defaults
DEFAULT_COOKIE_POLICY_VERSION=1.0

# ===================================
# Security & Rate Limiting
# ===================================
# Rate limiting (requests per minute)
RATE_LIMIT_PER_IP=60
RATE_LIMIT_PER_USER=120
RATE_LIMIT_PER_API_KEY=300

# IP reputation scoring enabled
IP_REPUTATION_ENABLED=true
IP_REPUTATION_THRESHOLD=30.0

# Adversarial detection enabled
ADVERSARIAL_DETECTION_ENABLED=true
ADVERSARIAL_DETECTION_THRESHOLD=0.7

# ===================================
# Email Configuration (Optional)
# ===================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@artlockr.com
EMAIL_FROM_NAME=ArtLock

# ===================================
# Monitoring & Logging
# ===================================
SENTRY_DSN=  # Optional: Sentry error tracking
SENTRY_ENVIRONMENT=development

# Log file path
LOG_FILE_PATH=logs/artlockr.log

# ===================================
# External Services (Optional)
# ===================================
# Redis for caching (optional)
REDIS_URL=redis://localhost:6379/0

# S3 for backup storage (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=artlockr-backups
AWS_REGION=us-east-1

# ===================================
# Scheduled Tasks
# ===================================
# AI image scanning schedule
SCAN_SCHEDULE=daily  # hourly, daily, weekly
SCAN_AI_IMAGES_DIR=/path/to/ai/images
SCAN_INCREMENTAL=true

# ===================================
# Development Only
# ===================================
# Reload on code changes
RELOAD=true

# Enable SQL query logging
SQL_ECHO=false

# Seed database on startup
SEED_DATABASE=false
